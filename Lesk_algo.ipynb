   "source": [
    "import nltk\n",
    "from nltk.corpus import wordnet as wn\n",
    "syns = wn.synsets('bank')\n",
    "print(syns)\n",
    "sentences = ['I went to the bank to deposit my money']\n",
    "from nltk.wsd import lesk\n",
    "context=lesk(sentences,'bank','n')\n",
    "print(context)\n",
    "print(\"definition:\",context.definition())\n"
   ]
  }
